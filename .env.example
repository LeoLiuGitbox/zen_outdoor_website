# ── Database ─────────────────────────────────────────────
# 本地开发用 SQLite（无需安装任何数据库）
DATABASE_URL="file:./dev.db"

# 生产环境用 PostgreSQL / Supabase 时取消注释：
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/zen_outdoor?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/zen_outdoor?schema=public"

# ── Supabase（生产环境使用）──────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"

# ── Afterpay / Zip (via Stripe) ───────────────────────────
# Afterpay is supported natively through Stripe — no separate keys needed

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@zenoutdoor.com.au"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_PHONE="+61 2 XXXX XXXX"
NEXT_PUBLIC_COMPANY_EMAIL="info@zenoutdoor.com.au"
NEXT_PUBLIC_COMPANY_ADDRESS="Sydney, NSW, Australia"
